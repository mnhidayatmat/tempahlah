# --- Tempahlah WA sidecar config ---

# Loopback ONLY. Never expose this port publicly.
PORT=3001
HOST=127.0.0.1

# Shared bearer token Laravel sends on every request. Generate with:
#   openssl rand -hex 32
SIDECAR_AUTH_TOKEN=

# HMAC-SHA256 secret used to sign webhook callbacks to Laravel. Same value
# as WHATSAPP_WEBHOOK_SECRET in Laravel's .env.
WEBHOOK_SECRET=

# Where the sidecar POSTs lifecycle / inbound events. Loopback to Laravel.
LARAVEL_WEBHOOK_URL=http://127.0.0.1/api/wa/webhook

# Where each tenant's Baileys auth state lives on disk. Survives restarts.
# Must be writable by the user the systemd unit runs as.
SESSION_DIR=/var/lib/tempahlah-wa-sessions

# Per-session minimum gap between outbound messages, in milliseconds.
# Random jitter of +/-30% is added on top.
SEND_MIN_GAP_MS=8000

# Drop inbound messages older than this many seconds at the source. On
# reconnect WhatsApp flushes every message that queued while the device was
# offline; without this the AI agent would reply to long-past messages "out of
# the blue". Keep aligned with Laravel's AGENT_MAX_INBOUND_AGE_MINUTES (5 min).
MAX_INBOUND_AGE_SECONDS=300

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
