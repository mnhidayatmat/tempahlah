APP_NAME="Tempahlah"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Apex host that tenant subdomains hang off. Production: tempahlah.com.
# Local: add hosts entries (127.0.0.1 tempahlah.test acme.tempahlah.test) and use tempahlah.test:8000.
TENANT_DOMAIN=tempahlah.com
APP_TIMEZONE=Asia/Kuala_Lumpur

APP_LOCALE=ms
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ms_MY

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tempahlah
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
; Leading dot — shares the session across tenant subdomains (e.g. .tempahlah.com).
SESSION_DOMAIN=.tempahlah.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@tempahlah.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=tempahlah-media
AWS_USE_PATH_STYLE_ENDPOINT=false

TOYYIBPAY_BASE_URL=https://dev.toyyibpay.com
TOYYIBPAY_SECRET_KEY=
TOYYIBPAY_CATEGORY_CODE=

BILLPLZ_BASE_URL=https://www.billplz-sandbox.com/api/v3
BILLPLZ_API_KEY=
BILLPLZ_COLLECTION_ID=
BILLPLZ_SIGNATURE=

FCM_PROJECT_ID=
FCM_CREDENTIALS_PATH=storage/app/firebase-credentials.json

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI="${APP_URL}/oauth/google/callback"

MARKETPLACE_COMMISSION_RATE=0.03
MARKETPLACE_TRIAL_DAYS=7

SST_RATE=0.08
TOURISM_TAX_PER_NIGHT_FOREIGNER=10.00

VITE_APP_NAME="${APP_NAME}"
