APP_NAME="Tempahlah"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Apex host that tenant subdomains hang off. Production: tempahlah.com.
# Local: add hosts entries (127.0.0.1 tempahlah.test acme.tempahlah.test) and use tempahlah.test:8000.
TENANT_DOMAIN=tempahlah.com
APP_TIMEZONE=Asia/Kuala_Lumpur

APP_LOCALE=ms
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ms_MY

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tempahlah
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
; 1 year (minutes). Long-lived so hosts stay signed in; the remember-me cookie
; (set on every login) re-authenticates even past this if the session is swept.
SESSION_LIFETIME=525600
SESSION_ENCRYPT=false
SESSION_PATH=/
; Leading dot — shares the session across tenant subdomains (e.g. .tempahlah.com).
SESSION_DOMAIN=.tempahlah.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=spaces
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=ses
MAIL_FROM_ADDRESS="noreply@tempahlah.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=tempahlah-media
AWS_USE_PATH_STYLE_ENDPOINT=false

# Digital Ocean Spaces (primary object storage).
# Uploads auto-prefixed by `root` on the `spaces` disk in config/filesystems.php.
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=wbl-storage
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_CDN_URL=https://wbl-storage.sgp1.cdn.digitaloceanspaces.com
DO_SPACES_ROOT=tempahlah

# Tempahlah's OWN Billplz merchant account — used ONLY to charge tenants the
# RM 49/mo subscription. Hosts connect their own gateway (Toyyibpay / Billplz /
# SecurePay) under /dashboard/integrations to take guest booking payments; those
# credentials are stored encrypted per tenant and never read from here.
#
# Leave BILLPLZ_API_KEY blank to keep platform billing switched off (checkout is
# hidden and subscriptions:bill-cycle no-ops).
BILLPLZ_API_KEY=
BILLPLZ_COLLECTION_ID=
BILLPLZ_SIGNATURE=
BILLPLZ_SANDBOX=true

# Days before a trial/period ends that the next RM 49 bill is issued, and how
# long that bill stays payable.
SUBSCRIPTION_ISSUE_LEAD_DAYS=3
SUBSCRIPTION_INVOICE_DUE_DAYS=14
SUBSCRIPTION_GRACE_DAYS=7
PAID_TRIAL_DAYS=7
PAID_TIER_PRICE=49.00
ULTRA_TIER_PRICE=89.00

# Affiliate / referral program (all optional — sensible defaults in config).
# Affiliates earn AFFILIATE_DEFAULT_RATE % of every subscription payment made
# by a referred tenant for AFFILIATE_DURATION_MONTHS after first conversion;
# commissions hold as pending for AFFILIATE_HOLD_DAYS before becoming payable.
AFFILIATE_DEFAULT_RATE=20
AFFILIATE_DURATION_MONTHS=12
AFFILIATE_COOKIE_DAYS=60
AFFILIATE_HOLD_DAYS=30

# Stripe recurring billing (platform-owned keys — Tempahlah charges its
# tenants). With no secret key + Pro price id the Stripe UI stays hidden.
# STRIPE_PRICE_ID = the recurring MYR 49/mo Pro Price; STRIPE_PRICE_ID_ULTRA
# = the recurring MYR 89/mo Ultra Price (unset → Ultra checkout unavailable).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_ULTRA=

FCM_PROJECT_ID=
FCM_CREDENTIALS_PATH=storage/app/firebase-credentials.json

# WhatsApp driver: baileys | cloud_api | deeplink | null
WHATSAPP_DRIVER=baileys

# Baileys sidecar (Node service on the same droplet, loopback only).
# Must match wa-sidecar/.env values.
WHATSAPP_SIDECAR_URL=http://127.0.0.1:3001
WHATSAPP_SIDECAR_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# Optional Cloud API credentials (used when WHATSAPP_DRIVER=cloud_api).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── AI agent (Pro feature) ──────────────────────────────────────────
# Provide ONE OR MORE of these — tenants pick a provider in settings
# from whatever has a key configured.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=

AGENT_DEFAULT_PROVIDER=anthropic
AGENT_DEFAULT_MODEL=claude-haiku-4-5-20251001

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI="${APP_URL}/oauth/google/callback"

# "Sign in with Google" reuses the GOOGLE_CALENDAR_* credentials by default
# (same Google Cloud project). Override only if you want a separate OAuth
# client. The redirect URI below MUST be added to the OAuth client's
# "Authorized redirect URIs" list in Google Cloud Console.
GOOGLE_SIGNIN_CLIENT_ID=
GOOGLE_SIGNIN_CLIENT_SECRET=
GOOGLE_SIGNIN_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Meta (Facebook) Pixel — ID from Meta Events Manager. Leave blank to disable
# (the pixel snippet is only rendered on public marketing pages when set).
FACEBOOK_PIXEL_ID=

MARKETPLACE_COMMISSION_RATE=0.0
MARKETPLACE_TRIAL_DAYS=7

SST_RATE=0.08
TOURISM_TAX_PER_NIGHT_FOREIGNER=10.00

VITE_APP_NAME="${APP_NAME}"
